# Specify the C++ standard
CXX_STD = CXX17

# Compiler flags (Apple clang: OpenMP via -Xpreprocessor)
PKG_CXXFLAGS = -Xpreprocessor -fopenmp -O3 -Wall -Wextra

# Include directories
PKG_CPPFLAGS = -I"../inst/include" \
  -I"/opt/homebrew/opt/highs/include" \
  -I"/opt/homebrew/opt/highs/include/highs" \
  -I"/opt/homebrew/opt/nlohmann-json/include" \
  -I"/opt/homebrew/opt/libomp/include"

# Libraries to link against
PKG_LIBS = -L"/opt/homebrew/opt/highs/lib" -lhighs \
  -L"/opt/homebrew/opt/libomp/lib" -lomp
